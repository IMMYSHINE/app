<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Immy Portfolio</title>
    <link rel="stylesheet" href="style.css">
</head>
<body>

    <nav>
        <div class="container nav-content">
            <div class="logo">IMMY</div>
            <ul class="nav-links">
                <li><a href="#home">Home</a></li>
                <li><a href="#about">About</a></li>
                <li><a href="#skills">Skills</a></li>
                <li><a href="#projects">Projects</a></li>
                <li><a href="#contact">Contact</a></li>
            </ul>
        </div>
    </nav>

    <section id="home" class="hero">
        <div class="container hero-flex">
            <div class="hero-image">
                <img src="my photo.jpeg " alt="Immy" class="this.src='profile-img">
            </div>
            <div class="hero-text">
                <h1>Hi, I'm Immy</h1>
                <p>Welcome to my technical portfolio. I am a student and intern focused on web development and software architecture.</p>
            </div>
        </div>
    </section>

    <section id="about" class="container section-padding">
        <h2 class="section-title">About Me</h2>
        <p class="center-text">I am currently finalizing my internship and working on professional reports at Victoria University. I specialize in building responsive layouts and clean code.</p>
    </section>

    <section id="skills" class="container section-padding">
        <h2 class="section-title">My Skills</h2>
        <div class="skills-grid">
            <div class="skill-box">
                <span class="skill-title">HTML5</span>
                <img src="HTML.jpeg" alt="HTML">
            </div>
            <div class="skill-box">
                <span class="skill-title">CSS3</span>
                <img src="CSS.jpeg" alt="CSS">
            </div>
            <div class="skill-box">
                <span class="skill-title">JavaScript</span>
                <img src="  Javascript.jpeg " alt="JavaScript">
            </div>
            <div class="skill-box">
                <span class="skill-title">GitHub</span>
                <img src="  github.jpeg  " alt="GitHub">
            </div>
        </div>
    </section>

    <section id="projects" class="container section-padding">
        <h2 class="section-title">Projects</h2>
        <div class="project-list">
            <div class="project-card">
                <h3>Portfolio Website</h3>
                <p>Created using HTML and CSS with a focus on responsive navigation and clean layout.</p>
            </div>
            <div class="project-card">
                <li><a href="INTERNSHIP LOGBOOK.docx " class="project-card"></a></li>
                 <div class="tag">Development</div>
                <h3>Internship Logbook</h3>
                <p>Documentation of weekly progress, including React and Firebase integration.</p>
            </div>
        </div>
    </section>

    <section id="contact" class="container section-padding">
        <h2 class="section-title">Contact</h2>
        <div class="contact-form">
            <input type="text" placeholder="Your Name">
            <input type="email" placeholder="Your Email">
            <textarea placeholder="Your Message" rows="4"></textarea>
            <button type="submit" class="submit-btn">Send Message</button>
        </div>
    </section>

    <footer>
    <div class="social-links">
        <a href="https://github.com/IMMYSHINE/app.git " target="_blank"><i class="fab fa-github"></i></a>
    </div>
</footer>
  <button id="scrollTop" class="scroll-btn">↑</button>

    <script src=" script.js"></script>
</body>
</html>